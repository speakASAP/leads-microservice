datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Lead {
  id            String               @id @default(uuid())
  status        String               @default("new")
  sourceService String
  sourceUrl     String?
  sourceLabel   String?
  message       String               @db.Text
  preferredChannel String?
  fallbackChannels Json?
  marketingConsent Boolean?
  consentSource String?
  consentCapturedAt DateTime?
  unsubscribedAt DateTime?
  confirmationToken String?          @unique
  confirmedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  contactMethods  LeadContactMethod[]
  submissions     LeadSubmission[]
  lifecycleEvents LeadLifecycleEvent[]
  marketingApprovalEvidence LeadMarketingApprovalEvidence[]

  @@index([createdAt])
  @@index([sourceService])
}

model LeadContactMethod {
  id        String   @id @default(uuid())
  leadId    String
  type      String
  value     String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model LeadSubmission {
  id         String   @id @default(uuid())
  leadId     String
  payloadJson Json
  createdAt  DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

model LeadMarketingApprovalEvidence {
  id                             String   @id @default(uuid())
  leadId                         String
  idempotencyKey                 String   @unique
  approvalId                     String
  campaignId                     String
  approvedAt                     DateTime
  purposeCode                    String
  channel                        String
  audienceCount                  Int
  eligibleCount                  Int
  retentionExpectation           String
  humanApprovalReferencePresent  Boolean  @default(false)
  approvedByPresent              Boolean  @default(false)
  workspaceIdPresent             Boolean  @default(false)
  contentVersionPresent          Boolean  @default(false)
  eligibilityEligible            Boolean
  eligibilityReasons             Json?
  returnedContactMethodCount     Int      @default(0)
  recordedAt                     DateTime @default(now())
  lead                           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, recordedAt])
  @@index([approvalId])
  @@index([campaignId])
  @@index([recordedAt])
}


model LeadLifecycleEvent {
  id             String   @id @default(uuid())
  leadId         String
  eventId        String   @unique
  eventType      String
  eventVersion   Int
  occurredAt     DateTime
  producer       String
  correlationId  String?
  idempotencyKey String?  @unique
  dataClass      String
  payload        Json
  consumerRoutes Json?
  recordedAt     DateTime @default(now())
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, occurredAt])
  @@index([eventType])
  @@index([recordedAt])
}
